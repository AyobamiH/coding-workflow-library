const args = parseArgs(process.argv.slice(2));
let targetRepo = args.repo || DEFAULT_REPO;
const dryRun = args.dryRun || args.explain || args.explainNext;
let selectedLane = null;
let activeCheckpointRun = null;

const evidence = [];
const actions = [];
const filesChanged = [];

main();

function main() {
  try {
    if (args.status) {
      printCheckpointStatus(targetRepo);
      return;
    }

    if (args.doctor) {
      printDoctor();
      return;
    }

    if (args.listApprovals) {
      printApprovalRegistry();
      return;
    }

    if (args.explainBoundary) {
      printBoundaryExplanation(args.explainBoundary);
      return;
    }

    if (args.resume) {
      const result = runResume();
      printResumeReport(result);
      process.exitCode = result.exitCode || 0;
      return;
    }

    if (args.listRoutes) {
      printRouteList();
      process.exit(0);
    }

    if (args.listLanes) {
      printLaneList();
      process.exit(0);
    }

    readControlFiles();
    let active;
    if (args.lane) {
      const state = laneState.readState(args.stateFile);
      selectedLane = laneState.getLane(state, args.lane);
      targetRepo = args.repo || selectedLane.repo_path || targetRepo;
      active = activeWorkItemFromLane(selectedLane);
    } else {
      const ledgerText = readText("work-ledger.md");
      active = findActiveWorkItem(ledgerText, targetRepo);
    }
    const status = active.currentStatus || "Unknown";
    const route = routeStatus(status, active);

    actions.push(`selected work item: ${active.heading || "latest ledger entry"}`);
    actions.push(`current status: ${status}`);
    actions.push(`next skill: ${route.skill}`);
    actions.push(`required authority/grant: ${route.required_authority || route.permission || "none"}`);

    if (!dryRun) {
      activeCheckpointRun = createCheckpointRun({ active, route });
      completeCheckpoint(activeCheckpointRun, "inspect", { branch: gitBranch(targetRepo), head: gitHead(targetRepo) });
      completeCheckpoint(activeCheckpointRun, "route", { status, skill: route.skill, job: route.kind || route.nextAction || "unknown" });
      if (route.kind === "human-boundary" || route.kind === "permission-boundary") {
        completeCheckpoint(activeCheckpointRun, "permission", { granted: false, reason: "human-boundary" });
      } else if (!permissionGranted(route)) {
        completeCheckpoint(activeCheckpointRun, "permission", { granted: false, reason: "permission-required" });
      } else {
        completeCheckpoint(activeCheckpointRun, "permission", { granted: true });
        startCheckpoint(activeCheckpointRun, "execute");
      }
    }

    let result;
    if (route.kind === "human-boundary" || route.kind === "permission-boundary") {
      result = stopAtBoundary(route, active);
    } else if (!permissionGranted(route)) {
      result = needsJohn(route, active);
    } else if (route.kind === "github-handoff") {
      result = runGithubHandoff(active);
    } else if (route.kind === "pr-readiness") {
      result = runPrReadiness(active);
    } else if (route.kind === "pr-merge") {
      result = runPrMerge(active);
    } else if (route.kind === "deployment-plan") {
      result = runDeploymentPlan(active);
    } else if (route.kind === "supabase-preflight") {
      result = runSupabasePreflight(active);
    } else if (route.kind === "supabase-tooling-auth") {
      result = runSupabaseToolingAuth(active);
    } else if (route.kind === "supabase-link-secret-readiness") {
      result = runSupabaseLinkSecretReadiness(active);
    } else if (route.kind === "scheduler-draft-pr") {
      result = runSchedulerDraftPr(active);
    } else if (route.kind === "scheduler-pr-merge") {
      result = runSchedulerPrMerge(active);
    } else if (route.kind === "supabase-secret-function-deploy") {
      result = runSupabaseSecretFunctionDeploy(active);
    } else if (route.kind === "runtime-negative-verification") {
      result = runRuntimeNegativeVerification(active);
    } else if (route.kind === "function-secret-deploy-negative-runtime") {
      result = runFunctionSecretDeployNegativeRuntime(active);
    } else if (route.kind === "controlled-success-invocation") {
      result = runControlledSuccessInvocation(active);
    } else if (route.kind === "scheduled-run-monitoring-handoff") {
      result = runScheduledRunMonitoringHandoff(active);
    } else if (route.kind === "zero-output-pipeline-investigation") {
      result = runZeroOutputPipelineInvestigation(active);
    } else if (route.kind === "zero-output-observability-patch") {
      result = runZeroOutputObservabilityPatch(active);
    } else if (route.kind === "observability-pr-recovery") {
      result = runObservabilityPrRecovery(active);
    } else if (route.kind === "zero-output-observability-deploy") {
      result = runZeroOutputObservabilityDeploy(active);
    } else if (route.kind === "observability-run-recheck") {
      result = runObservabilityRunRecheck(active);
    } else if (route.kind === "scheduler-application-decision") {
      result = runSchedulerApplicationDecision(active);
    } else if (route.kind === "scheduler-vault-design-apply") {
      result = runSchedulerVaultDesignApply(active);
    } else if (route.kind === "verification-bundle-self-test") {
      result = runVerificationBundleSelfTest(active);
    } else if (route.kind === "local-skill-workpack") {
      result = runLocalSkillWorkpack(active);
    } else if (route.kind === "cloudflare-opstruth-packaging-bundle") {
      result = runCloudflareOpstruthPackagingBundle(active);
    } else if (route.kind === "clean-temp-readiness-smoke") {
      result = runCleanTempReadinessSmoke(active);
    } else if (route.kind === "license-package-candidate") {
      result = runLicensePackageCandidate(active);
    } else if (route.kind === "package-candidate-dry-run") {
      result = runPackageCandidateDryRun(active);
    } else if (route.kind === "cli-entrypoint-package-smoke") {
      result = runCliEntrypointPackageSmoke(active);
    } else if (route.kind === "github-open-source-handoff") {
      result = runGithubOpenSourceHandoff(active);
    } else if (route.kind === "first-version-tag") {
      result = runFirstVersionTag(active);
    } else if (route.kind === "v0-2-local-prep") {
      result = runV020LocalPrep(active);
    } else if (route.kind === "workflow-corpus-recovery") {
      result = runWorkflowCorpusRecovery(active);
    } else {
      result = notImplemented(route, active);
    }

    if (activeCheckpointRun) finalizeCheckpointRun(activeCheckpointRun, result);

    if (!dryRun && selectedLane) {
      updateSelectedLane(result, route);
    } else if (!dryRun) {
      appendLedger({
        status: result.ledgerStatus || result.finalStatus,
        result,
        active,
        route,
      });
      appendRunLog({
        dryRun: false,
        status,
        result,
        active,
        route,
      });
    }

    printReport(result, active, route);
    process.exit(result.exitCode || 0);
  } catch (error) {
    if (activeCheckpointRun) stopCheckpointRun(activeCheckpointRun, error.message || "unhandled error");
    const result = {
      finalStatus: "BLOCKED",
      summary: error.message,
      exitCode: 1,
    };
    printReport(result, {}, { skill: "coding-workflow-orchestrator-skill" });
    process.exit(1);
  }
}

function parseArgs(rawArgs) {
  const parsed = {
    allow: new Set(),
    dryRun: false,
    doctor: false,
    explain: false,
    explainNext: false,
    explainBoundary: null,
    resume: false,
    status: false,
    listApprovals: false,
    listRoutes: false,
    listLanes: false,
    untilBlocked: false,
    lane: null,
    stateFile: laneState.defaultStateFile(),
    repo: null,
  };

  for (let index = 0; index < rawArgs.length; index += 1) {
    const arg = rawArgs[index];
    if (arg === "--dry-run") {
      parsed.dryRun = true;
      continue;
    }
    if (arg === "--doctor") {
      parsed.doctor = true;
      continue;
    }
    if (arg === "--resume") {
      parsed.resume = true;
      continue;
    }
    if (arg === "--status") {
      parsed.status = true;
      continue;
    }
    if (arg === "--explain") {
      parsed.explain = true;
      continue;
    }
    if (arg === "--explain-next") {
      parsed.explainNext = true;
      continue;
    }
    if (arg === "--explain-boundary") {
      parsed.explainBoundary = rawArgs[index + 1];
      index += 1;
      if (!parsed.explainBoundary) die("--explain-boundary requires a boundary type");
      continue;
    }
    if (arg === "--list-approvals") {
      parsed.listApprovals = true;
      continue;
    }
    if (arg === "--list-routes") {
      parsed.listRoutes = true;
      continue;
    }
    if (arg === "--list-lanes") {
      parsed.listLanes = true;
      continue;
    }
    if (arg === "--until-blocked") {
      parsed.untilBlocked = true;
      continue;
    }
    if (arg === "--lane") {
      parsed.lane = rawArgs[index + 1];
      index += 1;
      if (!parsed.lane) die("--lane requires a lane id");
      continue;
    }
    if (arg === "--state-file") {
      parsed.stateFile = rawArgs[index + 1];
      index += 1;
      if (!parsed.stateFile) die("--state-file requires a path");
      continue;
    }
    if (arg === "--repo") {
      parsed.repo = rawArgs[index + 1];
      index += 1;
      if (!parsed.repo) die("--repo requires an absolute path");
      continue;
    }
    if (arg === "--allow") {
      const value = rawArgs[index + 1];
      index += 1;
      if (!value) die("--allow requires a permission name");
      if (!ALLOWED_FLAGS.has(value)) {
        die(`unsupported permission flag: ${value}`);
      }
      parsed.allow.add(value);
      continue;
    }
    if (arg === "--help" || arg === "-h") {
      printHelp();
      process.exit(0);
    }
    die(`unknown argument: ${arg}`);
  }

  return parsed;
}

