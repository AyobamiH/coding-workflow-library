Lane mode reads and updates only the selected local lane. If --lane is omitted, legacy work-ledger.md routing remains available.
Legacy --allow route flags still work; authority-class flags now mean objective-level authority for that consequence class.
Dry-run and explain modes do not mutate target repos, lane state, work-ledger.md, or runs/skill-runs.md.`);
}

function printDoctor() {
  const registryPath = path.join(LIBRARY_ROOT, "state", "approval-registry.json");
  let registryStatus = "missing";
  try {
    const registry = autonomousBoundaries.loadApprovalRegistry(registryPath);
    const validation = autonomousBoundaries.validateApprovalRegistry(registry);
    registryStatus = `valid (${validation.approvals} approvals)`;
  } catch (error) {
    registryStatus = `invalid: ${error.message}`;
  }

  console.log("# run-next autonomy doctor");
  console.log(`workflow states: ${autonomousBoundaries.WORKFLOW_STATES.join(", ")}`);
  console.log(`boundary types: ${autonomousBoundaries.BOUNDARY_TYPES.join(", ")}`);
  console.log(`approval registry: ${registryStatus}`);
  console.log("automatic verified PR merge policy: enabled for workflow-authored, scoped, passing, unchanged-head PRs under normal repository rules");
  console.log("completion policy: PR merge is followed by post-merge validation before COMPLETED");
}

function printApprovalRegistry() {
  const registryPath = path.join(LIBRARY_ROOT, "state", "approval-registry.json");
  const registry = autonomousBoundaries.loadApprovalRegistry(registryPath);
  autonomousBoundaries.validateApprovalRegistry(registry);
  console.log("# approval registry");
  console.log(`path: ${path.relative(LIBRARY_ROOT, registryPath)}`);
  console.log(`version: ${registry.version}`);
  const approvals = Array.isArray(registry.approvals) ? registry.approvals : [];
  console.log(`approvals: ${approvals.length}`);
  for (const approval of approvals) {
    console.log(`- ${approval.approvalId}: ${approval.status}; scope=${approval.scope.join(", ")}`);
  }
  if (!approvals.length) console.log("No committed approvals. Runtime approvals may remain local-only when they contain operational context.");
}

function printBoundaryExplanation(type) {
  const result = autonomousBoundaries.classifyBoundary({ boundaryType: type, reason: "Boundary explanation requested." });
  console.log("# boundary explanation");
  console.log(`boundary_type: ${result.boundary_type}`);
  console.log(`workflow state: ${result.state}`);
  console.log(`boundary_reason: ${result.boundary_reason}`);
  console.log(`evidence: ${result.evidence.join(", ") || "none"}`);
  console.log(`why_autonomous_resolution_is_unsafe_or_impossible: ${result.why_autonomous_resolution_is_unsafe_or_impossible}`);
  console.log(`safe to continue automatically: ${result.safeToContinueAutomatically ? "yes" : "no"}`);
  console.log(`exact_human_input_required: ${result.exact_human_input_required}`);
  console.log(`resume_condition: ${result.resume_condition}`);
  console.log(`resume_command: ${result.resume_command}`);
}

function printLaneList() {
  const state = laneState.readState(args.stateFile);
  console.log(`# Workflow Lanes\n\nState file: ${args.stateFile}\nLanes: ${state.lanes.length}\n`);
  for (const lane of state.lanes) {
    console.log(`## ${lane.lane_id}`);
    console.log(`Name: ${lane.display_name}`);
    console.log(`Status: ${lane.status}`);
    console.log(`Current state: ${lane.current_state}`);
    console.log(`Next permission: ${lane.next_permission || "none"}`);
    if (lane.objective) {
      const objective = objectiveAuthority.normalizeObjective(lane.objective);
      const grants = objectiveAuthority.AUTHORITY_CLASSES.filter((name) => objective.authority[name]).join(", ") || "none";
      console.log(`Objective: ${objective.id}`);
      console.log(`Authority: ${grants}`);
    }
    console.log("");
  }
  console.log("This command reads local lane metadata only. State files must not contain secrets.");
}

function activeWorkItemFromLane(lane) {
  return {
    heading: `Lane: ${lane.lane_id}`,
    text: "",
    activeRepo: lane.repo_path,
    currentObjective: lane.notes || `Continue lane ${lane.lane_id}`,
    currentStatus: lane.current_state,
    selectedSkill: "coding-workflow-orchestrator-skill",
    laneId: lane.lane_id,
    laneStatus: lane.status,
    monitoringBaseline: lane.monitoring_baseline || "",
    rawLane: lane,
  };
}

function printRouteList() {
  const routeFile = path.join(LIBRARY_ROOT, "routes", "skill-routes.json");
  if (!fs.existsSync(routeFile)) die("missing route metadata: routes/skill-routes.json");

  let parsed;
  try {
    parsed = JSON.parse(fs.readFileSync(routeFile, "utf8"));
  } catch (error) {
    die(`route metadata is not valid JSON: ${error.message}`);
  }

  const routes = Array.isArray(parsed.routes) ? parsed.routes : [];
  console.log(`# Skill Routes

Route file: routes/skill-routes.json
Routes: ${routes.length}

${routes.map((route) => {
    const states = Array.isArray(route.ledger_states_handled) ? route.ledger_states_handled.join("; ") : "";
    return [
      `## ${route.id || "(missing id)"}`,
      `Skill: ${route.skill_file || "(missing skill file)"}`,
      `Authority grant: ${route.permission_flag || "(missing legacy grant flag)"}`,
      `States: ${states || "(none)"}`,
      `Success: ${route.success_ledger_state || "(missing success state)"}`,
      `Blocked: ${route.blocked_ledger_state || "(missing blocked state)"}`,
      `Next: ${route.next_permission || "(missing next permission)"}`,
    ].join("\n");
  }).join("\n\n")}

This command only reads local route metadata. It does not update the ledger, call external services, or mutate repos.`);
}

function readControlFiles() {
  for (const file of ["AGENTS.md", "RUNBOOK.md", "tools.md", "work-ledger.md"]) {
    const full = path.join(LIBRARY_ROOT, file);
    if (!fs.existsSync(full)) die(`missing required control file: ${file}`);
    fs.readFileSync(full, "utf8");
    evidence.push(`read ${file}`);
  }
}

function readText(relativePath) {
  return fs.readFileSync(path.join(LIBRARY_ROOT, relativePath), "utf8");
}

function findActiveWorkItem(ledgerText, repo) {
  const sections = ledgerText
    .split(/\n(?=## \d{4}-\d{2}-\d{2} - )/)
    .map((section) => section.trim())
    .filter(Boolean);

  const parsed = sections.map((section) => {
    const heading = (section.match(/^## (.+)$/m) || [])[1] || "";
    return {
      heading,
      text: section,
      activeRepo: cleanField(extractField(section, "Active repo")),
      currentObjective: cleanField(extractField(section, "Current objective")),
      currentStatus: cleanField(extractField(section, "Current status")),
      selectedSkill: cleanField(extractField(section, "Selected skill")),
    };
  });

  const repoMatches = parsed.filter((section) => section.activeRepo === repo);
  if (repoMatches.length > 0) return repoMatches[repoMatches.length - 1];
  if (repo) {
    return {
      heading: `No ledger entry for ${repo}`,
      text: "",
      activeRepo: repo,
      currentObjective: "Create or select a ledger item before mutation",
      currentStatus: "No ledger item for repo",
      selectedSkill: "coding-workflow-orchestrator-skill",
    };
  }
  if (parsed.length > 0) return parsed[parsed.length - 1];
  die("work-ledger.md has no parseable work items");
}

function extractField(section, label) {
  const pattern = new RegExp(`^\\* ${escapeRegExp(label)}:\\s*(.+)$`, "m");
  const match = section.match(pattern);
  return match ? match[1] : "";
}

function cleanField(value) {
  return String(value || "")
    .replace(/`/g, "")
    .replace(/\.$/, "")
    .trim();
}

function routeStatus(status, active = {}) {
  const normalized = status.toLowerCase();
  const activeObjective = active.rawLane?.objective ? objectiveAuthority.normalizeObjective(active.rawLane.objective) : null;

  if (
    activeObjective?.id === "release-coding-workflow-library-v0-2-0" ||
    activeObjective?.id === "release-coding-workflow-library-v0.2.0"
  ) {
    return {
      skill: "release-preflight-skill / skills-library-packaging-skill / github-handoff-skill",
      permission: null,
      requiresAuthority: ["local_execution"],
      kind: "v0-2-local-prep",
      nextAction: "prepare and verify every local/read-only v0.2.0 stage, then stop before remote publication",
    };
  }

  if (args.allow.has("workflow-corpus-recovery") && path.resolve(targetRepo) === LIBRARY_ROOT) {
    return {
      skill: "session-log-extraction-skill / coding-workflow-orchestrator-skill",
      permission: "workflow-corpus-recovery",
      requiresAuthority: ["local_execution"],
      kind: "workflow-corpus-recovery",
      nextAction: "validate or regenerate the private workflow corpus, verify coverage, and stop before remote publication",
    };
  }

  if (normalized === "no ledger item for repo") {
    return {
      skill: "repo-map-skill / coding-workflow-orchestrator-skill",
      permission: null,
      kind: "human-boundary",
      finalStatus: "NEEDS LEDGER ENTRY",
      nextPermission: "add a work-ledger.md item for this repo",
      nextAction: "add a work-ledger.md item for this repo before any mutating action",
    };
  }

  if (normalized === "ready to commit with caveats") {
    return {
      skill: "github-handoff-skill / scripts/committer",
      permission: "commit",
      kind: "not-implemented",
      nextAction: "run exact-file committer workflow",
    };
  }

  if (normalized === "committed locally, not pushed" || normalized === "needs github auth gate") {
    return {
      skill: "github-auth-gate-skill",
      permission: "auth-check",
      kind: "not-implemented",
      nextAction: "run GitHub auth gate",
    };
  }

  if (normalized === "needs john token replacement") {
    return {
      skill: "github-auth-gate-skill",
      permission: null,
      kind: "human-boundary",
      finalStatus: "NEEDS JOHN",
      nextAction: "replace or remove invalid local runtime token outside chat",
    };
  }

  if (normalized === "auth pass for github handoff") {
    return {
      skill: "github-handoff-skill",
      permission: "github-handoff",
      alternatePermission: "push-pr",
      kind: "github-handoff",
      nextAction: "create/switch feature branch, push feature branch only, and create or confirm PR",
    };
  }

  if (normalized === "pr opened, not merged") {
    return {
      skill: "github-handoff-skill / PR readiness inspection",
      permission: "pr-readiness",
      alternatePermission: "github-handoff",
      kind: "pr-readiness",
      nextAction: "inspect PR readiness and stop before merge",
    };
  }

  if (normalized === "pr ready for merge approval") {
    return {
      skill: "github-handoff-skill / PR merge handoff",
      permission: "pr-merge",
      kind: "pr-merge",
      nextAction: "merge PR #11 into main and stop before deployment planning",
    };
  }

  if (normalized === "merged, not deployed") {
    return {
      skill: "cloudflare-deploy-skill / supabase deployment planning",
      permission: "deployment-plan",
      kind: "deployment-plan",
      nextAction: "inspect source and produce deployment plan without deploying",
    };
  }

  if (normalized === "deployment plan ready, not deployed") {
    return {
      skill: "cloudflare-deploy-skill / supabase deployment execution planning",
      permission: "supabase-preflight",
      kind: "supabase-preflight",
      nextAction: "inspect Supabase execution prerequisites and draft exact execution sequence without executing it",
    };
  }

  if (normalized === "scheduler migration draft merged, supabase mutation still gated") {
    return {
      skill: "github-handoff-skill / scheduler PR #12 readiness and merge gate",
      permission: "scheduler-pr-merge",
      kind: "scheduler-pr-merge",
      nextAction: "verify already-merged scheduler PR #12 evidence and stop before any Supabase mutation",
    };
  }

  if (normalized === "supabase execution preflight ready, not executed") {
    return {
      skill: "cloudflare-deploy-skill / Supabase tooling/auth setup",
      permission: "supabase-tooling-auth",
      kind: "supabase-tooling-auth",
      nextAction: "verify Supabase CLI tooling and read-only project access without linking or mutating Supabase",
    };
  }

  if (
    normalized === "needs john: supabase access token missing" ||
    normalized === "needs john: supabase access token invalid" ||
    normalized === "needs john: supabase token lacks project access" ||
    normalized === "needs john: supabase project ref mismatch" ||
    normalized === "blocked: node/npx/supabase cli unavailable" ||
    normalized === "env file format issue"
  ) {
    return {
      skill: "cloudflare-deploy-skill / Supabase tooling/auth setup",
      permission: "supabase-tooling-auth",
      kind: "supabase-tooling-auth",
      nextAction: "retry Supabase tooling/auth verification after local credential or env correction",
    };
  }

  if (normalized === "supabase tooling/auth ready, not linked") {
    return {
      skill: "cloudflare-deploy-skill / Supabase link and secret readiness",
      permission: "supabase-link-secret-readiness",
      kind: "supabase-link-secret-readiness",
      nextAction: "link local repo to Supabase project and ensure local import secret readiness without remote secret setup or deploy",
    };
  }

  if (normalized === "supabase linked and local secret ready, not deployed") {
    return {
      skill: "cloudflare-deploy-skill / scheduler migration draft and GitHub handoff",
      permission: "scheduler-draft-pr",
      kind: "scheduler-draft-pr",
      nextAction: "draft guarded local scheduler migration, run local checks, exact-file commit, push feature branch, and open PR",
    };
  }

  if (
    normalized === "scheduler migration pr opened, not merged" ||
    normalized === "scheduler migration draft merged, supabase mutation still gated"
  ) {
    return {
      skill: "github-handoff-skill / scheduler PR #12 readiness and merge gate",
      permission: "scheduler-pr-merge",
      kind: "scheduler-pr-merge",
      nextAction: "inspect scheduler PR #12, merge only if still open and clean, then stop before any Supabase mutation",
    };
  }

  if (normalized === "scheduler migration draft merged, not applied" || normalized === "blocked: unexpected target repo changes") {
    return {
      skill: "supabase-function-deploy-skill / Supabase remote secret setup and single Edge Function deploy",
      permission: "supabase-secret-function-deploy",
      kind: "supabase-secret-function-deploy",
      nextAction: "verify source/auth/env, set remote import secret, deploy only import-reddit-tips, and stop before scheduler/runtime work",
    };
  }

  if (normalized === "function deployed and remote secret set, scheduler not applied") {
    return {
      skill: "runtime-verification-skill / deployed function negative runtime verification",
      permission: "runtime-negative-verification",
      kind: "runtime-negative-verification",
      nextAction: "run only OPTIONS, non-POST, unauthenticated POST, invalid scheduler secret, and anon-only rejection checks, then stop before any success path",
    };
  }

  if (normalized === "runtime negative checks passed, scheduler not applied") {
    return {
      skill: "supabase-scheduler-vault-skill / scheduler application decision",
      permission: "scheduler-application-decision",
      kind: "scheduler-application-decision",
      nextAction: "prove a safe scheduler secret-storage path, apply only import-reddit-tips-daily if proven, otherwise stop blocked",
    };
  }

  if (normalized === "runtime negative checks failed, scheduler blocked") {
    return {
      skill: "security-hardening-review-skill / runtime failure triage",
      permission: null,
      kind: "permission-boundary",
      finalStatus: "Runtime negative checks failed, scheduler blocked",
      nextPermission: "approve runtime failure triage and source patch plan",
      nextAction: "review failing negative runtime evidence before scheduler application",
    };
  }

  if (
    normalized === "function deployed, negative runtime verified, success path not run" ||
    normalized === "function deployed, dry-run runtime verified, success path not run"
  ) {
    return {
      skill: "runtime-verification-skill / controlled scheduler-path success invocation",
      permission: "controlled-success-invocation",
      kind: "controlled-success-invocation",
      nextAction: "collect read-only pet_tips metadata, run exactly one valid scheduler-secret POST, collect read-only after metadata, and stop",
    };
  }

  if (
    normalized === "controlled success invocation completed" ||
    normalized === "scheduled run pending, production handoff ready"
  ) {
    return {
      skill: "production-handoff-skill / scheduled-run monitoring and production handoff",
      permission: "scheduled-run-monitoring-handoff",
      kind: "scheduled-run-monitoring-handoff",
      nextAction: "inspect scheduler metadata, cron run history, pet_tips metadata, source/docs evidence, and prepare production handoff without invoking the function",
    };
  }

  if (normalized === "scheduled run observed, production handoff ready") {
    return {
      skill: "route-trace-skill / runtime-verification-skill / error-evidence-skill",
      permission: "zero-output-investigation",
      kind: "zero-output-pipeline-investigation",
      nextAction: "trace staged candidate attrition with source, safe database metadata, and available read-only logs without invoking production",
    };
  }

  if (normalized === "zero-output pipeline investigation blocked") {
    if (!args.allow.has("zero-output-investigation")) {
      return {
        skill: "runtime-verification-skill / route-trace-skill / error-evidence-skill",
        permission: "zero-output-observability-patch",
        kind: "zero-output-observability-patch",
        nextAction: "prepare a local count-only observability patch and stop before commit, PR, deploy, or runtime observation",
      };
    }

    return {
      skill: "route-trace-skill / runtime-verification-skill / error-evidence-skill",
      permission: "zero-output-investigation",
      kind: "zero-output-pipeline-investigation",
      nextAction: "retry the read-only staged pipeline investigation when the missing evidence source is available",
    };
  }

  if (normalized === "expected empty input proven, production handoff ready") {
    return {
      skill: "production-handoff-skill",
      permission: null,
      kind: "permission-boundary",
      finalStatus: "Expected empty input proven, production handoff ready",
      nextPermission: "complete production handoff or configure additional source inputs separately",
      nextAction: "choose production handoff completion or a separately approved source-configuration lane",
    };
  }

  if (normalized === "zero-output root cause proven, production handoff pending decision") {
    return {
      skill: "error-evidence-skill / coding-workflow-orchestrator-skill",
      permission: null,
      kind: "permission-boundary",
      finalStatus: "Zero-output root cause proven, production handoff pending decision",
      nextPermission: "approve configuration/data remediation plan",
      nextAction: "review the proven non-code cause before any remediation mutation",
    };
  }

  if (normalized === "zero-output local fix drafted, not committed or deployed") {
    return {
      skill: "github-handoff-skill / build-verify-skill",
      permission: null,
      kind: "permission-boundary",
      finalStatus: "Zero-output local fix drafted, not committed or deployed",
      nextPermission: "review and approve exact-file Wagging fix commit",
