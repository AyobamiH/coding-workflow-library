{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.invalid/coding-workflow/approval-registry.schema.json",
  "title": "Coding Workflow Approval Registry",
  "type": "object",
  "required": [
    "version",
    "approvals"
  ],
  "additionalProperties": true,
  "properties": {
    "version": {
      "const": 1
    },
    "approvals": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "approvalId",
          "scope",
          "status"
        ],
        "additionalProperties": true,
        "properties": {
          "approvalId": {
            "type": "string",
            "minLength": 1
          },
          "scope": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "string",
              "minLength": 1
            }
          },
          "status": {
            "enum": [
              "required",
              "granted",
              "consumed",
              "expired",
              "denied",
              "revoked",
              "not_applicable"
            ]
          },
          "grantedAt": {
            "type": "string",
            "format": "date-time"
          },
          "expiresAt": {
            "type": "string",
            "format": "date-time"
          },
          "consumedAt": {
            "type": "string",
            "format": "date-time"
          }
        }
      }
    }
  }
}
